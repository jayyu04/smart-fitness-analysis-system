<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Camera PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- PoseOverlayView -->
    <com.example.collegeproject.PoseOverlayView
        android:id="@+id/poseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 鏡頭切換按鈕 (右上) -->
    <ImageButton
        android:id="@+id/flipCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_camera"
        android:background="@null"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:padding="16dp" />

    <!-- FPS 顯示 (左上) -->
    <TextView
        android:id="@+id/fpsTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS: 0"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:padding="16dp" />

    <!-- 底部資訊區 -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="start"
        android:padding="12dp"
        android:background="#60000000">

        <TextView
            android:id="@+id/tvSelectedPose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="動作: -"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重量: - kg"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvSets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="組數: -"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvReps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="次數: -"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvRestTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="休息時間: - 秒"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvCurrentSets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="目前組數(已完成): 0"
            android:textColor="#FF0000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvCurrentReps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本組次數: 0"
            android:textColor="#FF0000"
            android:textSize="16sp" />

        <!-- 角度進度條 -->
        <ProgressBar
            android:id="@+id/angleProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:padding="8dp" />
    </LinearLayout>

    <!-- 結束按鈕 (右下) -->
    <ImageButton
        android:id="@+id/btnEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@null"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:padding="20dp"
        android:layout_margin="16dp" />

    <!-- 休息倒數大字 -->
    <TextView
        android:id="@+id/tvRestCountDown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="64sp"
        android:textColor="@android:color/white"
        android:background="#80000000"
        android:visibility="gone" />

    <!-- 入場提示 (新加入) -->
    <TextView
        android:id="@+id/tvEntryHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="嘿！請正對鏡頭，讓右手一起入鏡吧，不要遮擋關節點"
        android:textSize="24sp"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_round_black50"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_centerInParent="true" />

</RelativeLayout>
